{
  "name": "rorschach-calculator-v2",
  "version": "2.1.6",
  "private": true,
  "scripts": {
    "docs:generate-corpus": "node scripts/generate-reference-corpus.mjs && node scripts/generate-reference-quality-report.mjs && node scripts/generate-reference-release-snapshot.mjs",
    "docs:audit-authoring": "node scripts/audit-reference-authoring.mjs",
    "docs:generate-embeddings:openai": "node scripts/generate-reference-embeddings.mjs openai",
    "docs:generate-vector-release-snapshot": "node scripts/generate-reference-vector-release-snapshot.mjs",
    "docs:qa-corpus": "node scripts/generate-reference-quality-report.mjs && node scripts/generate-reference-release-snapshot.mjs",
    "docs:assert-runtime-ready": "node scripts/assert-reference-runtime-ready.mjs",
    "docs:assert-vector-runtime-ready": "node scripts/assert-reference-vector-runtime-ready.mjs",
    "docs:verify-release": "node scripts/verify-reference-release.mjs",
    "ops:release-status": "node scripts/show-reference-release-status.mjs",
    "ops:vector-status": "node scripts/show-reference-vector-status.mjs",
    "ops:promote-vectors": "node scripts/promote-reference-vector-runtime.mjs",
    "ops:deploy-context": "node scripts/show-deploy-context.mjs",
    "docs:evaluate-rag:ko": "npm run docs:generate-corpus && node scripts/run-reference-eval.mjs ko",
    "docs:evaluate-rag:es": "npm run docs:generate-corpus && node scripts/run-reference-eval.mjs es",
    "docs:evaluate-rag:en": "npm run docs:generate-corpus && node scripts/run-reference-eval.mjs en",
    "docs:evaluate-rag:ja": "npm run docs:generate-corpus && node scripts/run-reference-eval.mjs ja",
    "docs:evaluate-rag:pt": "npm run docs:generate-corpus && node scripts/run-reference-eval.mjs pt",
    "docs:evaluate-rag:all": "npm run docs:generate-corpus && node scripts/run-reference-eval.mjs ko && node scripts/run-reference-eval.mjs en && node scripts/run-reference-eval.mjs ja && node scripts/run-reference-eval.mjs es && node scripts/run-reference-eval.mjs pt",
    "ai:evaluate-contracts": "vitest run __tests__/aiHarness.test.ts __tests__/aiPromptContracts.test.ts __tests__/aiEvalFixtures.test.ts __tests__/aiEvalContracts.test.ts __tests__/aiMultiTurnEval.test.ts __tests__/aiEvalArtifacts.test.ts __tests__/aiHumanRubric.test.ts __tests__/aiHumanReviewRecords.test.ts __tests__/aiReleaseGate.test.ts __tests__/aiRetrievalContracts.test.ts",
    "ai:evaluate-artifacts": "node scripts/summarize-ai-eval-artifacts.mjs",
    "ai:evaluate-human-records": "node scripts/score-ai-human-review-records.mjs",
    "ai:release-gate": "node scripts/run-ai-release-gate.mjs",
    "ai:evaluate-live:openai": "vitest run __tests__/aiLiveEval.openai.test.ts --reporter=verbose",
    "ai:evaluate-live:openai:multiturn": "vitest run __tests__/aiLiveMultiTurn.openai.test.ts --reporter=verbose",
    "ai:evaluate-live:batch": "node scripts/run-openai-live-eval-batch.mjs",
    "i18n:audit": "node scripts/audit-i18n-copy.mjs",
    "dev": "npm run docs:generate-corpus && prisma generate && next dev",
    "build": "npm run i18n:audit && npm run docs:generate-corpus && npm run docs:assert-runtime-ready && prisma generate && next build",
    "start": "next start",
    "lint": "npm run i18n:audit && eslint",
    "test": "npm run docs:generate-corpus && npm run docs:assert-runtime-ready && prisma generate && vitest run",
    "security:secrets": "node scripts/security-scan.mjs",
    "security:audit": "npm audit --omit=dev --audit-level=moderate && npm audit --audit-level=moderate",
    "security:check": "npm run security:secrets && npm run security:audit",
    "ops:smoke-reference": "node scripts/smoke-reference-release.mjs",
    "ops:smoke-release": "npm run ops:smoke-reference",
    "ops:publish:direct-dry-run": "powershell -ExecutionPolicy Bypass -File scripts/publish.ps1 -UseCurrentRepo -DryRun",
    "ops:publish:mirror-dry-run": "powershell -ExecutionPolicy Bypass -File scripts/publish.ps1 -DryRun"
  },
  "overrides": {
    "@hono/node-server": "1.19.14",
    "postcss": "8.5.12"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@prisma/client": "^7.8.0",
    "gray-matter": "^4.0.3",
    "next": "^16.2.4",
    "openai": "^6.21.0",
    "pg": "^8.18.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "strip-markdown": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
