# Runtime RAG database
# Use a read-only Neon/Postgres role in production. It only needs SELECT on public
# reference-document vector tables. Prefer sslmode=verify-full in Neon URLs.
RAG_DATABASE_URL=<your-read-only-rag-database-url-with-sslmode-verify-full>

# Local corpus/vector maintenance only
# Do not add this write-capable URL to Vercel production runtime envs.
RAG_WRITE_DATABASE_URL=<your-local-write-rag-database-url-with-sslmode-verify-full>

# Optional anonymous AI response feedback
# This must be a dedicated Postgres database. Never reuse either RAG URL above.
# Apply the separate feedback migration before enabling the public UI flag.
AI_FEEDBACK_DATABASE_URL=<your-dedicated-feedback-database-url-with-sslmode-verify-full>
NEXT_PUBLIC_AI_FEEDBACK_ENABLED=0

# BYOK browser session cookie
# Required in production. Use at least 32 random characters.
BYOK_COOKIE_SECRET=<high-entropy-cookie-secret>

# Optional public analytics and site metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_COOKIEYES_SCRIPT_URL=
GOOGLE_SITE_VERIFICATION=
